# Microsoft Graph app credentials (CallRecords.Read.All application permission)
TenantId=
ClientId=
ClientSecret=

# MongoDB URI — inside docker-compose this is overridden to mongodb://mongo:27017/teams_con
MongoUri=mongodb://localhost:27017/teams_con

# API server — used by teams_con serve
ApiAddr=:8080

# API client URL — used by teams_con tui
ApiUrl=http://localhost:8080
